# AUST Backend Environment Variables
# Copy this file to .env and fill in your values

# Run mode (development, production)
RUN_MODE=development

# Database
AUST__DATABASE__URL=postgres://aust:aust_dev_password@localhost/aust_backend

# Storage (S3/MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AUST__STORAGE__PROVIDER=s3
AUST__STORAGE__BUCKET=aust-uploads
AUST__STORAGE__ENDPOINT=http://localhost:9000
AUST__STORAGE__REGION=us-east-1

# LLM Providers
AUST__LLM__DEFAULT_PROVIDER=ollama

# Claude (if using)
AUST__LLM__CLAUDE__API_KEY=your_claude_api_key_here
AUST__LLM__CLAUDE__MODEL=claude-sonnet-4-20250514

# OpenAI (if using)
AUST__LLM__OPENAI__API_KEY=your_openai_api_key_here
AUST__LLM__OPENAI__MODEL=gpt-4o

# Ollama (local)
AUST__LLM__OLLAMA__BASE_URL=http://localhost:11434
AUST__LLM__OLLAMA__MODEL=llama3.2-vision

# Maps API
AUST__MAPS__PROVIDER=google
AUST__MAPS__API_KEY=your_google_maps_api_key_here

# Email (IMAP/SMTP)
AUST__EMAIL__IMAP_HOST=imap.example.com
AUST__EMAIL__IMAP_PORT=993
AUST__EMAIL__SMTP_HOST=smtp.example.com
AUST__EMAIL__SMTP_PORT=587
AUST__EMAIL__USERNAME=your_email@example.com
AUST__EMAIL__PASSWORD=your_email_password
AUST__EMAIL__FROM_ADDRESS=umzug@example.com
AUST__EMAIL__FROM_NAME=AUST Umzüge

# Telegram Bot (Human-in-the-loop approval)
AUST__TELEGRAM__BOT_TOKEN=your_telegram_bot_token
AUST__TELEGRAM__ADMIN_CHAT_ID=your_telegram_chat_id

# Auth
AUST__AUTH__JWT_SECRET=change_this_to_a_long_random_string_in_production
AUST__AUTH__JWT_EXPIRY_HOURS=24
