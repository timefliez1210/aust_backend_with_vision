# Copy to docker/.env.staging and fill in your API keys.
# This file is gitignored — never commit .env.staging with real secrets.

# LLM (pick one — leave others empty)
# Default: Ollama via host machine (http://host.docker.internal:11434)
AUST__LLM__DEFAULT_PROVIDER=ollama
AUST__LLM__CLAUDE__API_KEY=
AUST__LLM__OPENAI__API_KEY=

# Maps / OpenRouteService (needed for distance calculation and Fahrkostenpauschale)
AUST__MAPS__API_KEY=your_ors_api_key_here
